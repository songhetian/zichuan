// Prisma schema for Asset Manager
// 领域词汇见 CONTEXT.md

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 配件模块
// ============================================================

// 配件分类（两级）
model ComponentCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  parentId  Int?
  parent    ComponentCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ComponentCategory[] @relation("CategoryTree")
  models    ComponentModel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 配件型号
model ComponentModel {
  id          Int      @id @default(autoincrement())
  name        String   // 型号名称，如 "i7-12700F"
  brand       String?  // 品牌
  categoryId  Int
  category    ComponentCategory @relation(fields: [categoryId], references: [id])
  stock       ComponentStock?
  stockLogs   ComponentStockLog[]
  // 模板配件关联
  templateComponents TemplateComponent[]
  // 设备当前配件关联
  assetComponents    AssetComponent[]
  // 用于分类+型号的唯一约束
  @@unique([categoryId, name])
}

// 配件库存（与型号一对一）
model ComponentStock {
  id        Int    @id @default(autoincrement())
  modelId   Int    @unique
  model     ComponentModel @relation(fields: [modelId], references: [id])
  quantity  Int    @default(0)
  updatedAt DateTime @updatedAt
}

// 配件库存流水
model ComponentStockLog {
  id         Int      @id @default(autoincrement())
  modelId    Int
  model      ComponentModel @relation(fields: [modelId], references: [id])
  type       StockLogType  // 入库/出库类型
  quantity   Int      // 正数入库，负数出库
  operator   String   // 操作员
  remark     String?  // 备注
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

enum StockLogType {
  PURCHASE_IN     // 采购入库
  UPGRADE_RETURN  // 升级退回（旧配件回库）
  ASSET_BUILD     // 组装设备出库
  UPGRADE_USE     // 升级使用
}

// ============================================================
// 设备模块
// ============================================================

// 设备分类（两级）
model AssetCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique  // 编号前缀，如 DN、WL
  parentId    Int?
  parent      AssetCategory?  @relation("AssetCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    AssetCategory[] @relation("AssetCategoryTree")
  templates   DeviceTemplate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 设备模板（BOM）
model DeviceTemplate {
  id          Int      @id @default(autoincrement())
  name        String   // 模板名称，如"标准办公电脑"
  categoryId  Int
  category    AssetCategory @relation(fields: [categoryId], references: [id])
  components  TemplateComponent[]
  assets      Asset[]
  unique      Boolean  @default(false) @map("is_unique")  // 每人只能拥有一台该模板设备
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([categoryId, name])
}

// 模板配件清单（BOM 明细）
model TemplateComponent {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    DeviceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  modelId     Int
  model       ComponentModel @relation(fields: [modelId], references: [id])
  quantity    Int      @default(1)  // 需要的数量
  @@unique([templateId, modelId])
}

// ============================================================
// 员工与组织模块
// ============================================================

// 部门
model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  employees Employee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 员工
model Employee {
  id          Int      @id @default(autoincrement())
  employeeNo  String   @unique  // 工号
  name        String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  phone       String?
  email       String?
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// 资产模块（后续添加）
// ============================================================

// 设备实体
model Asset {
  id              Int      @id @default(autoincrement())
  assetNo         String   @unique  // 设备编号，如 DN-0001
  name            String
  templateId      Int
  template        DeviceTemplate @relation(fields: [templateId], references: [id])
  status          AssetStatus @default(IDLE)
  employeeId      Int?     // 当前使用人
  employee        Employee? @relation(fields: [employeeId], references: [id])
  location        String?  // 存放位置
  purchaseDate    DateTime? // 采购日期
  warrantyMonths  Int?     // 保修期（月）
  notes           String?
  components      AssetComponent[]
  lifecycleLogs   LifecycleLog[]
  stocktakeRecords StocktakeRecord[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([employeeId])
  @@index([templateId])
  @@index([status])
}

// 设备当前配件配置
model AssetComponent {
  id        Int    @id @default(autoincrement())
  assetId   Int
  asset     Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  modelId   Int
  model     ComponentModel @relation(fields: [modelId], references: [id])
  quantity  Int    @default(1)
  @@unique([assetId, modelId])
}

// 生命周期日志
model LifecycleLog {
  id         Int      @id @default(autoincrement())
  assetId    Int
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action     LifecycleAction
  fromStatus AssetStatus?
  toStatus   AssetStatus?
  employeeId Int?     // 相关人员（分配/归还时）
  fromEmployeeId Int? // 调拨时使用
  operator   String
  remark     String?
  createdAt  DateTime @default(now())

  @@index([assetId])
  @@index([createdAt])
  @@index([action])
}

enum AssetStatus {
  IDLE            // 闲置
  IN_USE          // 在用
  IN_MAINTENANCE  // 维修中
  SCRAPPED        // 报废
}

enum LifecycleAction {
  CREATED           // 设备创建（按模板生成）
  ALLOCATED         // 分配
  RETURNED          // 归还
  TRANSFERRED       // 调拨
  UPGRADED          // 升级
  MAINTENANCE_START // 送修
  MAINTENANCE_DONE  // 维修完成
  SCRAPPED          // 报废
}

// ============================================================
// 系统模块
// ============================================================

// 管理员
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt 哈希
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 系统日志
model SystemLog {
  id         Int      @id @default(autoincrement())
  module     String   // 模块
  action     String   // 动作
  detail     String   // 详情
  operator   String   // 操作员
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([module])
  @@index([operator])
}

// 盘点
model StocktakeSession {
  id          Int      @id @default(autoincrement())
  name        String   // 盘点任务名称
  description String?
  status      StocktakeStatus @default(OPEN)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  records     StocktakeRecord[]
}

enum StocktakeStatus {
  OPEN        // 进行中
  COMPLETED   // 已完成
}

model StocktakeRecord {
  id             Int      @id @default(autoincrement())
  sessionId      Int
  session        StocktakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  asset          Asset    @relation(fields: [assetId], references: [id])
  assetId        Int
  expectedStatus AssetStatus
  actualStatus   StocktakeResult
  remark         String?
  @@unique([sessionId, assetId])
}

enum StocktakeResult {
  NORMAL    // 正常
  MISSING   // 盘亏
  EXTRA     // 盘盈
}
