{
  "name": "zichuan",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "资产管理系统 - 企业资产管理解决方案",
  "scripts": {
    "install": "node scripts/prisma-generate.js",
    "dev": "next dev",
    "predev": "node scripts/prisma-generate.js",
    "build": "prisma generate && next build",
    "start": "next start",
    "setup": "npm install && node scripts/db-init.js && prisma migrate dev --name init && npx tsx prisma/seed.ts",
    "dev:full": "node scripts/kill-node.js && node scripts/db-init.js && prisma migrate dev --name init && npx tsx prisma/seed.ts && next dev",
    "prod": "NODE_ENV=production prisma generate && next build && next start",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "docker:ps": "docker compose ps",
    "docker:deploy": "docker compose up -d --build && docker compose up db-init"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.18.0",
    "@radix-ui/react-checkbox": "^1.3.7",
